{
  "openapi": "3.0.4",
  "info": {
    "title": "Maquinaria API",
    "description": "APIs de integración con el módulo SincoMyE del ERP SincoErp.",
    "version": "v1"
  },
  "servers": [
    {
      "url": "/api/v4/Maquinaria",
      "description": "Ruta base del servicio Maquinaria"
    }
  ],
  "paths": {
    "/api/causas-falla": {
      "get": {
        "tags": [
          "CausasFalla"
        ],
        "summary": "Lista causas de falla del catálogo global",
        "description": "Devuelve las causas de falla del catálogo global EQV4.FallaCausa. Filtro por texto en descripción. Sentinel '-1' trae todo el catálogo. Tope de 5000 causas por respuesta. Revalidación de caché via ETag diario.",
        "operationId": "ListarCausasFalla",
        "parameters": [
          {
            "name": "texto",
            "in": "query",
            "description": "Texto de búsqueda obligatorio. Usá '-1' para traer todo el catálogo.",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Maquinaria.Core.Application.CausasFalla.Listar.ListarCausasFallaResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad Request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Maquinaria.Core.Application.ErrorResponse"
                }
              }
            }
          },
          "304": {
            "description": "Not Modified"
          }
        }
      }
    },
    "/api/equipos": {
      "get": {
        "tags": [
          "Equipos"
        ],
        "summary": "Lista equipos del usuario",
        "description": "Devuelve los equipos visibles para el usuario según sus obras asignadas en EQV4.UsuariosObra. Soporta filtro de búsqueda por descripción, placa o ID. Tope de 5000 equipos por respuesta. Revalidación de caché via ETag diario.",
        "operationId": "ListarEquipos",
        "parameters": [
          {
            "name": "filtro",
            "in": "query",
            "description": "Filtro de búsqueda (opcional). Vacío o -1 devuelve todos. Máximo 100 caracteres.",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Maquinaria.Core.Application.Equipos.Listar.ListarEquiposResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad Request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Maquinaria.Core.Application.ErrorResponse"
                }
              }
            }
          },
          "304": {
            "description": "Not Modified"
          }
        }
      }
    },
    "/api/equipos/{codigo}/dictamen-vigente": {
      "put": {
        "tags": [
          "Equipos"
        ],
        "summary": "Actualiza el dictamen vigente de un equipo",
        "description": "Actualiza el dictamen operativo de un equipo (0=puede operar, 1=con restricción, 2=no puede operar). Idempotencia last-write-wins. Slice 11.",
        "operationId": "ActualizarDictamenEquipo",
        "parameters": [
          {
            "name": "codigo",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int32"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Maquinaria.Core.Application.Equipos.ActualizarDictamen.ActualizarDictamenEquipoResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad Request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Maquinaria.Core.Application.ErrorResponse"
                }
              }
            }
          },
          "404": {
            "description": "Not Found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Maquinaria.Core.Application.ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/partes-equipos": {
      "get": {
        "tags": [
          "PartesEquipos"
        ],
        "summary": "Lista partes de equipos del usuario",
        "description": "Devuelve las partes visibles para el usuario según sus obras asignadas en EQV4.UsuariosObra. Soporta filtro por EquipoId (-1 para todas las partes). Tope de 5000 partes por respuesta. Revalidación de caché via ETag diario.",
        "operationId": "ListarPartesEquipos",
        "parameters": [
          {
            "name": "idEquipo",
            "in": "query",
            "description": "ID del equipo (-1 para todas las partes visibles, o entero positivo para filtrar por equipo). Obligatorio.",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Maquinaria.Core.Application.PartesEquipos.Listar.ListarPartesEquiposResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad Request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Maquinaria.Core.Application.ErrorResponse"
                }
              }
            }
          },
          "304": {
            "description": "Not Modified"
          }
        }
      }
    },
    "/api/preoperacional-fallas": {
      "get": {
        "tags": [
          "PreoperacionalFallas"
        ],
        "summary": "Lista fallas preoperacionales visibles para el usuario",
        "description": "Devuelve las fallas preoperacionales de EQV4.PreoperacionalFallas, filtradas por rango de fechas, equipo y texto. Visibilidad limitada a obras del usuario. Sin caché HTTP (ETag no emitido).",
        "operationId": "ListarPreoperacionalFallas",
        "parameters": [
          {
            "name": "desde",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "hasta",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "equipoId",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "texto",
            "in": "query",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Maquinaria.Core.Application.PreoperacionalFallas.Listar.ListarPreoperacionalFallasResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad Request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Maquinaria.Core.Application.ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/preoperacional-fallas/cerrar": {
      "post": {
        "tags": [
          "PreoperacionalFallas"
        ],
        "summary": "Cierra (bulk) fallas preoperacionales abiertas",
        "description": "Recibe una lista de PODIds y un texto de observaciones; cierra (transición abierta→cerrada) las fallas visibles para el usuario actual. Idempotencia natural (no Idempotency-Key). Slice 9.",
        "operationId": "CerrarPreoperacionalFallas",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/Maquinaria.Core.Application.PreoperacionalFallas.Cerrar.CerrarPreoperacionalFallasCommand"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Maquinaria.Core.Application.PreoperacionalFallas.Cerrar.CerrarPreoperacionalFallasResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad Request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Maquinaria.Core.Application.ErrorResponse"
                }
              }
            }
          },
          "422": {
            "description": "Unprocessable Content",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Maquinaria.Core.Application.PreoperacionalFallas.Cerrar.ValidationErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/productos": {
      "get": {
        "tags": [
          "Productos"
        ],
        "summary": "Lista productos del catálogo global",
        "description": "Devuelve los productos del catálogo global EQV4.Productos. Filtro por texto en ProCod (cast a string) o ProDesc. Sentinel '-1' trae todo el catálogo. Tope de 5000 productos por respuesta. Revalidación de caché via ETag diario.",
        "operationId": "ListarProductos",
        "parameters": [
          {
            "name": "texto",
            "in": "query",
            "description": "Texto de búsqueda obligatorio. Usá '-1' para traer todo el catálogo.",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Maquinaria.Core.Application.Productos.Listar.ListarProductosResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad Request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Maquinaria.Core.Application.ErrorResponse"
                }
              }
            }
          },
          "304": {
            "description": "Not Modified"
          }
        }
      }
    },
    "/api/rutinas-monitoreo/migrar": {
      "post": {
        "tags": [
          "RutinasMonitoreo"
        ],
        "summary": "Migra rutinas de monitoreo desde Excel",
        "description": "Recibe un archivo .xlsx con la hoja 'Inspeccion Rutina de monitoreo' y persiste las rutinas e inspecciones en EQV4. La autorización la gestiona el host SincoMyE upstream. Soporta idempotencia via header Idempotency-Key.",
        "operationId": "MigrarRutinaMonitoreo",
        "requestBody": {
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "string",
                "format": "binary"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Maquinaria.Core.Application.RutinasMonitoreo.Migrar.MigrarRutinasMonitoreoResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad Request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Maquinaria.Core.Application.ErrorResponse"
                }
              }
            }
          },
          "409": {
            "description": "Conflict",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Maquinaria.Core.Application.ErrorResponse"
                }
              }
            }
          },
          "422": {
            "description": "Unprocessable Content",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Maquinaria.Core.Application.RutinasMonitoreo.Migrar.ValidationErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/rutinas-monitoreo": {
      "get": {
        "tags": [
          "RutinasMonitoreo"
        ],
        "summary": "Lista rutinas de monitoreo asignadas a un equipo",
        "description": "Devuelve las rutinas de monitoreo activas asignadas al equipo indicado vía EQV4.RutinasMonitoreoEquipos, filtradas por visibilidad de obras del usuario. Slice 10.",
        "operationId": "ListarRutinasMonitoreoPorEquipo",
        "parameters": [
          {
            "name": "equipoId",
            "in": "query",
            "description": "ID del equipo cuyas rutinas se quieren listar (entero positivo, obligatorio).",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Maquinaria.Core.Application.RutinasMonitoreo.ListarPorEquipo.ListarRutinasMonitoreoPorEquipoResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad Request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Maquinaria.Core.Application.ErrorResponse"
                }
              }
            }
          },
          "304": {
            "description": "Not Modified"
          }
        }
      }
    },
    "/api/rutinas-monitoreo/items": {
      "get": {
        "tags": [
          "RutinasMonitoreo"
        ],
        "summary": "Lista items de una rutina de monitoreo para un equipo",
        "description": "Devuelve los items / checks de una rutina concreta asignada a un equipo. Ambos parámetros son obligatorios. Sin ETag — endpoint puramente online. Slice 12.",
        "operationId": "ListarItemsRutinaMonitoreo",
        "parameters": [
          {
            "name": "equipoId",
            "in": "query",
            "description": "ID del equipo (entero positivo, obligatorio).",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "rutinaId",
            "in": "query",
            "description": "ID de la rutina de monitoreo (entero positivo, obligatorio).",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Maquinaria.Core.Application.RutinasMonitoreo.ListarItems.ListarItemsRutinaMonitoreoResponse"
