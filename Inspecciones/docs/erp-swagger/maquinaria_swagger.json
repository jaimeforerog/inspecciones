            }
          },
          "400": {
            "description": "Bad Request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Maquinaria.Core.Application.ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/tipos-falla": {
      "get": {
        "tags": [
          "TiposFalla"
        ],
        "summary": "Lista tipos de falla del catálogo global",
        "description": "Devuelve los tipos de falla del catálogo global EQV4.TipoFalla. Filtro por texto en descripción. Sentinel '-1' trae todo el catálogo. Tope de 5000 tipos por respuesta. Revalidación de caché via ETag diario.",
        "operationId": "ListarTiposFalla",
        "parameters": [
          {
            "name": "texto",
            "in": "query",
            "description": "Texto de búsqueda obligatorio. Usá '-1' para traer todo el catálogo.",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Maquinaria.Core.Application.TiposFalla.Listar.ListarTiposFallaResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad Request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Maquinaria.Core.Application.ErrorResponse"
                }
              }
            }
          },
          "304": {
            "description": "Not Modified"
          }
        }
      }
    }
